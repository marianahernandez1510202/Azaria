# ===========================================
# Azaria Backend Environment Configuration
# ===========================================
# Copy this file to .env and configure your values

# Application
APP_ENV=production
APP_DEBUG=false
APP_URL=https://dtai.uteq.edu.mx

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=azaria
DB_USER=azaria
DB_PASS=your_password_here

# JWT Authentication
JWT_SECRET=your_jwt_secret_key_here_min_32_chars

# Email (optional)
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM=noreply@azaria.app

# Google Calendar (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
