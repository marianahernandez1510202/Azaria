<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /~azaria/

  # If the request is for an existing file or directory, serve it
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d

  # Don't rewrite API calls - let them pass to api/ subdirectory
  RewriteCond %{REQUEST_URI} !^/~azaria/api/

  # Rewrite everything else to index.html (React SPA)
  RewriteRule ^ index.html [QSA,L]
</IfModule>
